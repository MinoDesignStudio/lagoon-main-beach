---
import '../styles/global.css';
import { localBusiness, website } from '../lib/schema.js';
// Preload the above-the-fold fonts so the browser fetches them in parallel with
// the CSS (avoids the swap flash). ?url gives the hashed, base-aware path that
// matches what the stylesheet requests, so it's cached as one download.
import fontBody from '../fonts/font-2-6cc01798.woff2?url'; // Montserrat (latin)
import fontDisplay from '../fonts/font-3-cf513ad6.woff2?url'; // Siena (headings)

interface Props {
  title: string;
  description: string;
  /** Canonical path on the live domain, e.g. "/" or "/owners/" */
  path: string;
  /** Optional per-page social image, relative to /img (e.g. "owners-embedded-2.jpg") */
  image?: string;
  /** Page-specific JSON-LD blocks (e.g. ApartmentComplex, FAQPage, BreadcrumbList) */
  schema?: object[];
}

const { title, description, path, image = 'hero-pano.jpg', schema = [] } = Astro.props;

// LocalBusiness + WebSite render on every page; `schema` adds per-page blocks.
const jsonLd = [localBusiness, website, ...schema];

// The GitHub Pages build is a client-review preview: search engines must
// never index it, and canonicals always point at the future live domain.
const isPagesPreview = process.env.DEPLOY_TARGET === 'pages';
const canonical = new URL(path, 'https://lagoonmainbeach.com');
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
// Absolute URL for social cards, resolved against the active site origin.
const ogImage = new URL(`${base}img/${image}`, Astro.site);

// GA4: set the Measurement ID (G-XXXXXXXXXX) before go-live. Left empty so
// nothing loads until a real ID is in place; never loads on the preview build.
const GA_ID = '';
---
<!doctype html>
<html lang="en-AU">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="preload" href={fontBody} as="font" type="font/woff2" crossorigin />
<link rel="preload" href={fontDisplay} as="font" type="font/woff2" crossorigin />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{isPagesPreview && <meta name="robots" content="noindex, nofollow" />}
<link rel="icon" type="image/png" href={`${base}favicon.png`} />
<link rel="sitemap" href={`${base}sitemap-index.xml`} />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Lagoon Main Beach" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
{jsonLd.map((block) => (
  <script type="application/ld+json" is:inline set:html={JSON.stringify(block)} />
))}
{!isPagesPreview && GA_ID && (
  <>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
    <script is:inline define:vars={{ GA_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', GA_ID);
    </script>
  </>
)}
</head>
<body>
<slot />
</body>
</html>
